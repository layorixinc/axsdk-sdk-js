  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js",
      "source": "./src/lib.ts"
    },
    "./index.css": "./dist/lib.css"
  },
  "module": "./dist/lib.js",
  "main": "./dist/lib.js",

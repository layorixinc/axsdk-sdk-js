{
  "name": "@axsdk/browser",
  "version": "0.3.13",
  "private": false,
  "description": "axsdk browser - embed AXSDK widget in web",
  "keywords": [],
  "homepage": "https://github.com/layorixinc/axsdk-sdk-js",
  "bugs": {
    "url": "https://github.com/layorixinc/axsdk-sdk-js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/layorixinc/axsdk-sdk-js.git"
  },
  "license": "MIT",
  "author": "lordkeios@layorixinc.com",
  "type": "module",
  "exports": {
    ".": "./dist/axsdk-browser.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build --config vite.config.ts",
    "dev": "vite --config vite.config.ts",
    "release": "node ../../scripts/set-publish-deps.mjs && bun run build && npm publish --access=public",
    "build:workspace": "rm -rf node_modules && node ../../scripts/set-workspace-deps.mjs && bun install && bun run build"
  },
  "dependencies": {
    "@axsdk/core": "^0.3.8",
    "@axsdk/react": "^0.4.9",
    "qs": "^6.15.0",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "typescript": "^5",
    "vite": "^6"
  }
}
